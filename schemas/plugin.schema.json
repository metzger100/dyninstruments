{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://dyninstruments.local/schemas/plugin.schema.json",
  "title": "Dyninstruments plugin.json",
  "type": "object",
  "required": ["layouts"],
  "additionalProperties": false,
  "properties": {
    "layouts": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "required": ["name", "file"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "file": {
            "type": "string",
            "pattern": "^layouts/[A-Za-z0-9._-]+\\.json$"
          }
        }
      }
    }
  }
}
