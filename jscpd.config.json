{
  "absolute": true,
  "format": ["javascript", "css"],
  "ignore": [
    "node_modules/**",
    "coverage/**",
    "artifacts/**",
    "releases/**",
    "exec-plans/**",
    "documentation/**",
    "tests/**",
    "assets/**",
    "package-lock.json"
  ],
  "minLines": 30,
  "minTokens": 120,
  "reporters": ["console"],
  "threshold": 0.25
}
