{
  "globs": ["*.md", "documentation/**/*.md"],
  "ignores": ["artifacts/**", "coverage/**", "exec-plans/**", "node_modules/**", "releases/**"],
  "config": {
    "default": true,
    "MD012": false,
    "MD013": false,
    "MD022": false,
    "MD024": {
      "siblings_only": true
    },
    "MD029": false,
    "MD031": false,
    "MD032": false,
    "MD033": false,
    "MD036": false,
    "MD038": false,
    "MD040": false,
    "MD041": false,
    "MD056": false,
    "MD060": false
  }
}
